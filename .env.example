PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Postgres (local docker-compose values)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=expense_tracker
DB_USER=app
DB_PASSWORD=app

# Cloud SQL connector (production only — leave blank locally)
CLOUD_SQL_INSTANCE_CONNECTION_NAME=

# Auth
JWT_SECRET=change-me-in-production
JWT_TTL_SECONDS=3600
BCRYPT_COST=12
